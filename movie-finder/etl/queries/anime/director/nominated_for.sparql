# https://query.wikidata.org/
# anime -> director -> nominated_for
select distinct ?director ?nominated_for

with {    
    SELECT distinct ?anime
    WHERE {
        ?anime wdt:P31/wdt:P279* wd:Q1107 .
    }
} as %q0

with {
    SELECT distinct ?anime ?director
    WHERE {
        include %q0
        ?anime wdt:P57 ?director .
    }
} as %q1

where {
    include %q1
    ?director wdt:P1411 ?nominated_for .
}
