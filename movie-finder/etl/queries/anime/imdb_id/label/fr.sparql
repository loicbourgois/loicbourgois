# https://query.wikidata.org/
# anime -> imdb_id -> label -> fr
SELECT ?imdb_id ?imdb_id_label (lang(?imdb_id_label) as ?language)
with {
    SELECT distinct ?anime
    WHERE {
        ?anime wdt:P31/wdt:P279* wd:Q1107 .
    }
} as %q0
    
with {
    SELECT distinct ?anime ?imdb_id
    WHERE {
        include %q0
        ?anime wdt:P345 ?imdb_id .
    }
} as %q1
    
with {
    SELECT distinct ?imdb_id
    WHERE {
        include %q1
    }
} as %q

WHERE {
    include %q
    ?imdb_id rdfs:label ?imdb_id_label filter (lang(?imdb_id_label) = "fr").
}
