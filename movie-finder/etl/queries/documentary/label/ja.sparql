# https://query.wikidata.org/
# documentary -> label -> ja
SELECT ?documentary ?documentary_label (lang(?documentary_label) as ?language)
with {      
    SELECT distinct ?documentary
    WHERE {
        ?documentary wdt:P31/wdt:P279* wd:Q4164344 .
    }
} as %q0
WHERE {
    include %q0
    ?documentary rdfs:label ?documentary_label filter (lang(?documentary_label) = "ja").
}
