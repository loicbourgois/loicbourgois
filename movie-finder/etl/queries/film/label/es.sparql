# https://query.wikidata.org/
# film -> label -> es
SELECT ?film ?film_label (lang(?film_label) as ?language)
with {      
    SELECT distinct ?film
    WHERE {
        ?film wdt:P31/wdt:P279* wd:Q11424 .
    }
} as %q0
WHERE {
    include %q0
    ?film rdfs:label ?film_label filter (lang(?film_label) = "es").
}
